        {# ── Geolocalización del usuario ── #}
         {% if sesion.getSesion.usuarioTipo.id!=1 and sesion.getSesion.usuarioTipo.id!=8 %}
        <script>
            (function () {

                if (!navigator.geolocation) {
                    window.location.href = '{{ path("app_logout") }}';
                    return;
                }

                var modal           = document.getElementById('modal-geo');
                var modalBloqueada  = document.getElementById('modal-geo-bloqueada');
                var btnAceptar      = document.getElementById('btn-geo-aceptar');
                var errorMsg        = document.getElementById('geo-error-msg');
                var countdownEl     = document.getElementById('geo-countdown');
                var logoutUrl       = '{{ path("app_logout") }}';

                function hacerLogout() {
                    window.location.href = logoutUrl;
                }

                function mostrarInstruccionesYLogout() {

                    if (modal) {
                        modal.style.display = 'none';
                    }

                    modalBloqueada.style.display = 'flex';

                    var seg = 30;

                    countdownEl.textContent = seg;

                    var intervalo = setInterval(function () {

                        seg--;

                        countdownEl.textContent = seg;

                        if (seg <= 0) {

                            clearInterval(intervalo);

                            hacerLogout();
                        }

                    }, 1000);
                }

                function registrarGeo(lat, lng, ciudad, pais) {

                    fetch('{{ path("user_activity_log_geo") }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            lat: lat,
                            lng: lng,
                            ciudad: ciudad,
                            pais: pais
                        })
                    })
                    .then(function (r) {

                        if (!r.ok) {
                            throw new Error('Error guardando ubicación');
                        }

                        modal.style.display = 'none';
                    })
                    .catch(function () {

                        errorMsg.textContent = 'No se pudo registrar la ubicación.';
                        errorMsg.style.display = 'block';

                        setTimeout(function () {
                            hacerLogout();
                        }, 3000);
                    });
                }

                function enviarGeo(pos) {

                    var lat = pos.coords.latitude;
                    var lng = pos.coords.longitude;

                    fetch(
                        'https://nominatim.openstreetmap.org/reverse?format=json&lat=' + lat + '&lon=' + lng,
                        {
                            headers: {
                                'Accept-Language': 'es'
                            }
                        }
                    )
                    .then(function (r) {
                        return r.json();
                    })
                    .then(function (data) {

                        var addr = data.address || {};

                        var ciudad =
                            addr.city ||
                            addr.town ||
                            addr.village ||
                            addr.county ||
                            '';

                        var pais = addr.country || '';

                        registrarGeo(lat, lng, ciudad, pais);

                    })
                    .catch(function () {

                        registrarGeo(lat, lng, '', '');
                    });
                }

                function manejarError(err) {

                    console.log(err);

                    switch (err.code) {

                        case err.PERMISSION_DENIED:

                            // Usuario rechazó permiso
                            mostrarInstruccionesYLogout();

                            break;

                        case err.POSITION_UNAVAILABLE:

                        case err.TIMEOUT:

                        default:

                            btnAceptar.disabled = false;

                            btnAceptar.innerHTML =
                                '<i class="fas fa-location-arrow"></i> Reintentar';

                            errorMsg.textContent =
                                'No se pudo obtener la ubicación.';

                            errorMsg.style.display = 'block';
                    }
                }

                function solicitarGeo() {

                    btnAceptar.disabled = true;

                    btnAceptar.innerHTML =
                        '<i class="fas fa-spinner fa-spin"></i> Esperando permiso...';

                    errorMsg.style.display = 'none';

                    navigator.geolocation.getCurrentPosition(
                        enviarGeo,
                        manejarError,
                        {
                            enableHighAccuracy: true,
                            timeout: 15000,
                            maximumAge: 0
                        }
                    );
                }

                btnAceptar.addEventListener('click', solicitarGeo);

                function iniciar() {

                    if (navigator.permissions) {

                        navigator.permissions.query({
                            name: 'geolocation'
                        })
                        .then(function (result) {

                            console.log('Estado permiso:', result.state);

                            // Si el usuario bloqueó permanentemente
                            if (result.state === 'denied') {

                                mostrarInstruccionesYLogout();

                                return;
                            }

                            // Solo mostrar el modal si aún no ha dado permiso
                            if (result.state === 'prompt') {
                                modal.style.display = 'flex';
                            }

                            solicitarGeo();

                            // Detectar cambios dinámicos
                            result.onchange = function () {

                                if (result.state === 'denied') {
                                    mostrarInstruccionesYLogout();
                                }
                            };
                        });

                    } else {

                        // Safari / navegadores antiguos
                        modal.style.display = 'flex';

                        solicitarGeo();
                    }
                }

                iniciar();

            })();
    </script>
