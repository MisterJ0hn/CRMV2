                <tr>
                    <th>Participante</th>
                    <th>Rut</th>
                    <th>Persona</th>
                    <th>Razon Social</th>
                </tr>
                </thead>
                <tbody>
                    <!-- filas dinamicas -->
                </tbody>
            </table>
            </div>
            <div class="tab-pane fade" id="tabNotif">
                <table id="tablaNotificaciones" class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Rol</th>
                        <th>Estado</th>
