                // Aquí puedes manejar la respuesta si es necesario
                response=data;
                if(response.exito){
                    alert("Causa eliminada correctamente.");
                }else{
                    alert(response.mensaje);
                }

                window.location.reload();
                
            },
            error: function (xhr, ajaxOptions, thrownError) {
                alert(thrownError);
            }
        });
    }
}
{% endif %}
</script>
{% endblock %}
