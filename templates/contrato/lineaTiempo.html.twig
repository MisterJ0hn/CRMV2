<!-- Modal anexos movimiento -->
<div class="modal fade" id="modalAnexosMovimiento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Anexos de Movimiento</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="table-responsive">
                    <table id="tablaAnexosMovimiento" class="table table-bordered table-striped">
                        <thead class="table-primary">
                        <tr>
                            <th>Doc</th>
                            <th>Fecha</th>
                            <th>Referencia</th>
