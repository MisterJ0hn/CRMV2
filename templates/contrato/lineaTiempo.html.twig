                    </tr>
                    </thead>
                    <tbody>
                        <!-- filas dinamicas -->
                    </tbody>
                </table>
            </div>
            <div class="tab-pane fade" id="tabEscritos">
                <table id="tablaEscritos" class="table table-bordered table-striped">
