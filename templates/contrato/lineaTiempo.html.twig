          <div class="col-md-4"><strong>Tribunal:</strong> <span id="m_tribunal">-</span></div>
        </div>
        <div class="row">
            <div class="col-md-3 btn-demanda">
            </div>
            <div class="col-md-3 btn-anexo">
            </div>
            <div class="col-md-3 btn-certificado">
            </div>
            <div class="col-md-3 btn-ebook">
            </div>
             

        </div>
