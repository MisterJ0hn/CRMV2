                </table>
            
            </div>
            <div class="tab-pane fade" id="tabExhortos">
            <table id="tablaExhortos" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Rol Origen</th>
                    <th>Tipo Exhorto</th>
