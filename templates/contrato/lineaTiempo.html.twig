        if (mov.pdfAnexoNombre) {
            if(mov.pdfPrincipalDescargado==1){
                docCol += '<a href="{{url_web}}{{causa_pjud}}'+mov.causa_id+'/'+mov.pdfAnexoNombre+'" target="_blank" class="btn btn-sm btn-primary" title="Ver PDF Anexo (Rojo)" onclick="event.preventDefault(); abrirPDF("{{url_web}}{{causa_pjud}}'+mov.pdfAnexoNombre+'"); return false;"><i class="far fa-file-pdf" ></i></a>';
            }else{
                docCol += "<button type='button' class='btn btn-sm btn-primary' disabled ><i class='far fa-clock'></i></button>";
            
            }
        }
        if (!mov.pdfPrincipalNombre && !mov.pdfAnexoNombre) {
                docCol = '<span style="color:#999;font-size:12px;">Sin documentos</span>';
            
        }
        docCol += '</div>';
        anexosCol = '';
