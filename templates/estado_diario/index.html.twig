{% extends 'base.html.twig' %}

{% block title %}{{ pagina|default('Estado Diario') }}{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header">
        <a href="{{ path('estado_diario_new') }}" class="btn btn-primary"><i class="fas fa-file-upload"></i> Importar Estado Diario</a>
    </div>
    <div class="card-body">

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>{{ knp_pagination_sortable(origenes, 'Archivo', 'nombreArchivo') }} {% if origenes.isSorted('nombreArchivo') %} <i class="fas fa-sort"></i>{% endif %}</th>
                <th>{{ knp_pagination_sortable(origenes, 'Rut', 'rut') }} {% if origenes.isSorted('rut') %} <i class="fas fa-sort"></i>{% endif %}</th>
                <th>{{ knp_pagination_sortable(origenes, 'Fecha Estado Diario', 'fecha') }} {% if origenes.isSorted('fecha') %} <i class="fas fa-sort"></i>{% endif %}</th>
                <th>{{ knp_pagination_sortable(origenes, 'Usuario carga', 'usuarioCarga.nombre') }} {% if origenes.isSorted('usuarioCarga.nombre') %} <i class="fas fa-sort"></i>{% endif %}</th>
                <th>{{ knp_pagination_sortable(origenes, 'Fecha carga', 'fechaCarga') }} {% if origenes.isSorted('fechaCarga') %} <i class="fas fa-sort"></i>{% endif %}</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% for origen in origenes %}
            <tr>
                <td>{{ origen.id }}</td>
                <td>{{ origen.nombreArchivo }}</td>
                <td>{{ origen.rut }}</td>
                <td>{{ origen.fecha ? origen.fecha|date('d-m-Y') : '' }}</td>
                <td>{{ origen.usuarioCarga ? origen.usuarioCarga.nombre : '' }}</td>
                <td>{{ origen.fechaCarga ? origen.fechaCarga|date('Y-m-d H:i:s') : '' }}</td>
                <td><a href="{{ path('estado_diario_show', {'id': origen.id}) }}" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a></td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no hay estados diarios importados</td>
            </tr>
        {% endfor %}
        <div class="navigation">
               {{ knp_pagination_render(origenes,'@KnpPaginator/Pagination/twitter_bootstrap_v4_pagination.html.twig',{},{
               'position': 'centered',
               'rounded': true,
               }) }}
           </div>
        </tbody>
    </table>
</div>
</div>

{% endblock %}
