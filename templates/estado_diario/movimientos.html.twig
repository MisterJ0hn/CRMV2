{% extends 'base.html.twig' %}

{% block title %}{{ pagina|default('Movimientos Estado Diario') }}{% endblock %}

{% block body %}

<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col-sm-6 col-md-3">
                <small class="text-muted">Jurisdicción</small>
                <select name="bJurisdiccion" id="bJurisdiccion" class="form-control">
                    <option value="">Todas</option>
                    {% for jurisdiccion in jurisdicciones %}
                        <option value="{{ jurisdiccion.id }}">{{ jurisdiccion.nombre }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-sm-6 col-md-3">
                <small class="text-muted">Fecha Estado Diario</small>
                <input type="date" class="form-control" name="bFecha" id="bFecha" value="{{ fechaDefault }}">
            </div>
            <div class="col-sm-6 col-md-3">
                <small class="text-muted">Rut</small>
                <input type="text" class="form-control" name="bRut" id="bRut" placeholder="Ej: 16952077-1">
            </div>
            <div class="col-sm-6 col-md-3 d-flex align-items-end">
                <button class="btn btn-primary mr-2" id="btn-buscar"><i class="fas fa-search"></i> Buscar</button>
                <button type="button" class="btn btn-secondary" id="btn-limpiar">Limpiar</button>
            </div>
        </div>
    </div>
    <div class="card-header p-0 border-bottom-0">
        <ul class="nav nav-tabs" id="tabs-movimientos" role="tablist">
            <li class="nav-item">
                <a class="nav-link tab-link {% if tabInicial == 'no-leidos' %}active{% endif %}" href="#" data-tab="no-leidos">No leídos</a>
            </li>
            <li class="nav-item">
                <a class="nav-link tab-link {% if tabInicial == 'leidos' %}active{% endif %}" href="#" data-tab="leidos">Leídos</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <div id="resultado">
            <div class="text-center py-5">
                <i class="fas fa-spinner fa-spin fa-2x text-primary"></i>
            </div>
        </div>
    </div>
</div>

<script>
var tabActivo = '{{ tabInicial|default('no-leidos') }}';
var _csrfTokenLeido = '{{ csrf_token('estado_diario_leido') }}';

function buildFiltros() {
    var jurisdiccion = $('#bJurisdiccion').val() || '';
    var fecha = $('#bFecha').val() || '';
    var rut = $('#bRut').val() || '';
    return 'bJurisdiccion=' + encodeURIComponent(jurisdiccion) + '&bFecha=' + encodeURIComponent(fecha) + '&bRut=' + encodeURIComponent(rut);
}

function cargarMovimientos(tab, page) {
    tabActivo = tab;

    var url = '{{ path('estado_diario_movimientos_obtener_contenido') }}?tab=' + encodeURIComponent(tab) + '&' + buildFiltros();
    if (page && page > 1) {
        url += '&page=' + page;
    }

    $('#resultado').html('<div class="text-center py-5"><i class="fas fa-spinner fa-spin fa-2x text-primary"></i></div>');
    $.ajax({
        url: url,
        type: 'GET',
        dataType: 'json',
        success: function(data) {
            if (data.error) {
                $('#resultado').html('<div class="alert alert-danger m-3">' + data.error + '</div>');
                return;
            }
            $('#resultado').html(data.html);
        },
        error: function() {
            $('#resultado').html('<div class="alert alert-danger m-3">Error al cargar los datos.</div>');
        }
    });
}

$(document).ready(function() {
    cargarMovimientos(tabActivo);
});

$('.tab-link').on('click', function(e) {
    e.preventDefault();
    $('.tab-link').removeClass('active');
    $(this).addClass('active');
    cargarMovimientos($(this).data('tab'));
});

$('#btn-buscar').on('click', function() {
    cargarMovimientos(tabActivo);
});

$('#btn-limpiar').on('click', function() {
    $('#bJurisdiccion').val('');
    $('#bFecha').val('{{ fechaDefault }}');
    $('#bRut').val('');
    cargarMovimientos(tabActivo);
});

$(document).on('click', '#resultado a.page-link', function(e) {
    e.preventDefault();
    var url = $(this).attr('href');
    var page = 1;
    var match = url.match(/[?&]page=(\d+)/);
    if (match) { page = parseInt(match[1]); }
    cargarMovimientos(tabActivo, page);
});

$(document).on('click', '.btn-marcar-leido', function() {
    var boton = $(this);
    var id = boton.data('id');
    var fila = boton.closest('tr');

    boton.prop('disabled', true);

    $.ajax({
        url: '/estado_diario/movimientos/' + id + '/leido',
        type: 'POST',
        dataType: 'json',
        data: { _token: _csrfTokenLeido },
        success: function(data) {
            if (data.exito) {
                fila.fadeOut(200, function() { $(this).remove(); });
            } else {
                alert(data.mensaje || 'No se pudo marcar como leído.');
                boton.prop('disabled', false);
            }
        },
        error: function() {
            alert('Error al marcar como leído.');
            boton.prop('disabled', false);
        }
    });
});
</script>

{% endblock %}
