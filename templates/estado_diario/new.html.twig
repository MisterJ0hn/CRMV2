{% extends 'base.html.twig' %}

{% block title %}{{ pagina|default('Importar Estado Diario') }}{% endblock %}

{% block body %}

<div class="card">
    <div class="card-header">Importar Estado Diario</div>
    <div class="card-body">
        {% if error is defined %}
            <div class="alert alert-danger alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button>
                <h5><i class="icon fas fa-ban"></i> Error!</h5>
                {{ error }}
            </div>
        {% endif %}

        {{ form_start(form) }}
        <div class="row">
            <div class="col-sm-6 col-md-4">
                <small class="text-muted">Archivo Excel de Estado Diario</small><br>
                {{ form_row(form.url,{'label':false,'attr':{'accept':'.xlsx,.xls'}}) }}
            </div>
        </div>

        <button class="btn btn-primary">{{ button_label|default('Importar') }}</button>
        {{ form_end(form) }}
    </div>
</div>

{% endblock %}
