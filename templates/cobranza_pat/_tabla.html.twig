<div class="card-body table-responsive p-0" >
           
            <table class="table table-head-fixed text-nowrap table-striped table-sm">
                <thead>
                    <tr>
                        <th>{{ knp_pagination_sortable(cuotas, 'Folio', 'contrato.folioContrato') }} {% if cuotas.isSorted('contrato.folioContrato') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        <th>{{ knp_pagination_sortable(cuotas, 'AgendaId', 'contrato.agenda.id') }} {% if cuotas.isSorted('contrato.agenda.id') %} <i class="fas fa-sort"></i>{% endif %}</th>
                       
                        <!--<th>{{ knp_pagination_sortable(cuotas, 'Telefono', 'contrato.telefono') }} {% if cuotas.isSorted('contrato.telefono') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        -->
                      <th>{{ knp_pagination_sortable(cuotas, 'Cobrador', 'cobrador.nombre') }} {% if cuotas.isSorted('cobrador.nombre') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        
                        <th>{{ knp_pagination_sortable(cuotas, 'Cliente', 'contrato.nombre') }} {% if cuotas.isSorted('contrato.nombre') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        
                        <!--<th>{{ knp_pagination_sortable(cuotas, 'Rut', 'contrato.rut') }} {% if cuotas.isSorted('contrato.rut') %} <i class="fas fa-sort"></i>{% endif %}</th>-->
                        <!--<th>{{ knp_pagination_sortable(cuotas, 'Fecha Contrato', 'contrato.fechaCreacionVista') }} {% if cuotas.isSorted('contrato.fechaCreacionVista') %} <i class="fas fa-sort"></i>{% endif %}</th>-->
                        <th>{{ knp_pagination_sortable(cuotas, 'CuotaMora', 'fechaPago') }} {% if cuotas.isSorted('fechaPago') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        <th>D.Mora</th>
                        
                        <!--<th>DSG</th>-->
                        <th>$Cuota</th>
                        <th>$Mora</th>
                        <th>U.Pago</th>
                        <th>{{ knp_pagination_sortable(cuotas, 'U.Gestión', 'contrato.fechaUltimaGestion') }} {% if cuotas.isSorted('contrato.fechaUltimaGestion') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        <th>{{ knp_pagination_sortable(cuotas, 'U.Rspta', 'contrato.ultimaFuncion') }} {% if cuotas.isSorted('contrato.ultimaFuncion') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        <th>{{ knp_pagination_sortable(cuotas, 'Compromiso', 'contrato.fechaCompromiso') }} {% if cuotas.isSorted('contrato.fechaCompromiso') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        <th>C.Pgda</th>
                        <th>{{ knp_pagination_sortable(cuotas, 'Q.Gestión', 'contrato.qMov') }} {% if cuotas.isSorted('contrato.qMov') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        <th>{{ knp_pagination_sortable(cuotas, 'Anexo', 'contrato.isAnexo') }} {% if cuotas.isSorted('contrato.isAnexo') %} <i class="fas fa-sort"></i>{% endif %}</th>
                        <th><i class="fas fa-traffic-light"></i></th>        
                        <th><i class="far fa-credit-card text-success"></i></th>                                    
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
    
                {% for cuota in cuotas %}
              
                {% set contrato = cuota.contrato %}
                {% set enmora = cuota.monto - cuota.pagado %}
                {% set diferencia=(date('now').diff(cuota.fechaPago)) %}
                    <tr>
                        <td>{{ contrato.folioContrato }}</td>
                        <td>{{ contrato.agenda.id }}</td>
                         
                        
                       <!-- <td><a href="https://api.whatsapp.com/send?phone={{ contrato.cliente.telefono }}&text=" target="_blank">{{ contrato.cliente.telefono }}</a></td>-->
                        <td>
                            {% if cuota.cobrador %}
                                {{ cuota.cobrador.nombre }}
                            {% endif %}
                        </td>
                        <td>{{ contrato.cliente.nombre }}</td>
                       <!-- <td align="center">{{ contrato.cliente.rut }}</td>-->
                        <!--<td align="center">{{ contrato.fechaCreacionVista|date('d-m-Y H:i') }}</td>-->
                        <td align="center">{{ cuota.fechaPago|date('d-m-Y') }}</td>
                        <!--<td align="center">{{ diasmora(cuota.contrato.proximoVencimiento|date('Y-m-d')) }} dias</td>-->
                        
                        <td align="center">
                        {%  if cuota.fechaPago %}
                        {{ diasmora(cuota.fechaPago|date('Y-m-d'))<0?0:diasmora(cuota.fechaPago() |date('Y-m-d'))}} dias
                        {% endif %}
                         </td>
                        <td align="center">
                        {% if cuota.isMulta != true %}

                            ${{ cuota.monto|number_format(0,',','.') }}
                        {% endif %}
                        </td>
                        <td align="right">${{ montoDeudaPat(contrato.id)|number_format(0, ',', '.') }}</td>
                        
                        <td align="center">{{ ultimoPago(contrato.id) ? ultimoPago(contrato.id) |date('d-m-Y H:i') : '' }}</td>
                        <td align="center">{{ contrato.fechaUltimaGestion ? contrato.fechaUltimaGestion|date('Y-m-d') : '' }}</td>
                        <td align="center">{{ contrato.ultimaFuncion ? contrato.ultimaFuncion : '' }}</td>
                        <td align="center">{{ contrato.fechaCompromiso ? contrato.fechaCompromiso|date('d-m-Y'):''}}</td>
                        <td align="center">{{ totalesCobranza(contrato.id) }}</td>
                        <td align="center">{{ contrato.qMov }}</td>
                        <td align="center">
                            {% if contrato.isAnexo %}
                                <i class="fas fa-check"></i>
                            {% endif %}
                        </td>
                       
                        <td>
                           <span class="info-box-icon {{vencimiento.color}}"><i class="{{ vencimiento.icono }}"></i></span>
                        </td>
                       <td>
                       {% if contrato.aceptaSuscripcion==1 %}
                            
                        
                            {% if contrato.estadoSuscripcion != null %}
                                {% if contrato.estadoSuscripcion == "ACTIVA" %}
                                    <i class="far fa-credit-card text-success" title='Suscripción Activa'></i>
                                {% else %}
                                    <i class="far fa-credit-card text-danger" title='Suscripción Fallida'></i>
                                {% endif %}
                            {% else %}
                                <i class="far fa-credit-card text-warning" title='Suscripción en proceso'></i>
                            {% endif %}
                        {% endif %}
                       </td>
                        <td>
                            <a href="{{ path('cobranza_lote', {'id': contrato.id}) }}" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                            <a href="{{ path('vercobranza_view', {'id': contrato.id}) }}" class="btn btn-success btn-sm"><i class="far fa-eye"></i></a>
                            <a href="{{ path('contrato_linea_tiempo', {'id': contrato.id}) }}" class="btn btn-sm text-white bg-dark">LT</a>
                            <a href="{{ path('anexo_index', {'id': contrato.id}) }}" class="btn btn-info btn-sm"><i class="fas fa-file"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="16">No hay contratos</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="card-footer">
            <div class="card-footer clearfix">
                {# display navigation #}
           <div class="navigation">
               {{ knp_pagination_render(cuotas,'@KnpPaginator/Pagination/twitter_bootstrap_v4_pagination.html.twig',{},{
               'position': 'centered',
               'rounded': true,
               }) }}
           </div>
       </div>
            
</div>