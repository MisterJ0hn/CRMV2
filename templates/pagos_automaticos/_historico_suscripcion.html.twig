<section class="content">
        <div class="container-fluid">
    
        <!-- Timelime example  -->
            <div class="row">
                <div class="col-md-12">
                <!-- The time line -->
                    <div class="timeline">
                        <!-- timeline time label -->
                        <div class="time-label">
                        <span class="bg-red">{{contrato.fechaCreacion ? contrato.fechaCreacion|date('Y-m-d H:i:s') : '' }}</span>
                        </div>
                        <!-- /.timeline-label -->
                        <!-- timeline item -->
                         {% for suscripcion in suscripciones %}
                            
                        
                        <div class="time-label">
                            <span class="bg-green">{{ suscripcion.fechaRegistro ? suscripcion.fechaRegistro|date('Y-m-d H:i:s') : '' }}</span>
                        </div>
                        <div>
                            <i class="fas fa-clock bg-blue"></i>
                            <div class="timeline-item">
                                <div class="timeline-body">
                                    {{ suscripcion.observacion|raw }}
                                </div>                               
                            </div>
                        </div>
                        {% endfor %}
                        <div>
                            <i class="fas fa-clock bg-gray"></i>
                          </div>
                    </div>
                    
                </div>
                
            </div>
        </div>
    </section>