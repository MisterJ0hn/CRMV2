<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-Compatible" content="IE=edge">
  <title>Contraseña Caducada</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/build/adminlte/plugins/fontawesome-free/css/all.min.css">
  <link rel="stylesheet" href="/build/adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
  <link rel="stylesheet" href="/build/adminlte/dist/css/adminlte.min.css">
  <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700" rel="stylesheet">
</head>
<body class="hold-transition login-page">
  <div class="login-box" style="width: 420px;">
    <div class="login-logo">
      <b>Mi</b> CRM
    </div>

    <div class="card">
      <div class="card-body login-card-body">

        <div class="text-center mb-3">
          <i class="fas fa-lock fa-3x text-warning"></i>
        </div>

        <p class="login-box-msg">
          <strong>Tu contraseña ha caducado.</strong><br>
          Por seguridad debes establecer una nueva contraseña cada {{ diasExpiracion }} días.
        </p>

        {% for message in app.flashes('error') %}
          <div class="alert alert-danger alert-dismissible">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            <i class="fas fa-exclamation-triangle"></i> {{ message }}
          </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
          <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> {{ message }}
          </div>
        {% endfor %}

        {{ form_start(form, {'action': path('password_caducado'), 'method': 'POST'}) }}

          <div class="form-group">
            <small class="text-muted">Nueva contraseña</small>
            <div class="input-group">
              {{ form_widget(form.plainPassword.first, {
                'attr': {
                  'class': 'form-control pwd-principal',
                  'placeholder': 'Nueva contraseña',
                  'autocomplete': 'new-password'
                }
              }) }}
              <div class="input-group-append">
                <button type="button" class="btn btn-outline-secondary toggle-pwd" tabindex="-1">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>
            {% if form.plainPassword.first.vars.errors|length > 0 %}
              <div class="text-danger" style="font-size:0.85rem;">
                {% for error in form.plainPassword.first.vars.errors %}
                  <div>{{ error.message }}</div>
                {% endfor %}
              </div>
            {% endif %}
          </div>

          <div class="form-group">
            <small class="text-muted">Confirmar contraseña</small>
            <div class="input-group">
              {{ form_widget(form.plainPassword.second, {
                'attr': {
                  'class': 'form-control',
                  'placeholder': 'Repite la contraseña',
                  'autocomplete': 'new-password'
                }
              }) }}
              <div class="input-group-append">
                <button type="button" class="btn btn-outline-secondary toggle-pwd" tabindex="-1">
                  <i class="fas fa-eye"></i>
                </button>
              </div>
            </div>
            {% if form.plainPassword.second.vars.errors|length > 0 %}
              <div class="text-danger" style="font-size:0.85rem;">
                {% for error in form.plainPassword.second.vars.errors %}
                  <div>{{ error.message }}</div>
                {% endfor %}
              </div>
            {% endif %}
          </div>

          {% if form.plainPassword.vars.errors|length > 0 %}
            <div class="alert alert-danger">
              {% for error in form.plainPassword.vars.errors %}
                {{ error.message }}
              {% endfor %}
            </div>
          {% endif %}

          <div class="mb-3">
            <small class="text-muted">Requisitos de la contraseña:</small>
            <ul class="list-unstyled mt-1" style="font-size:0.8rem;">
              <li id="req-len"     class="text-danger"><i class="fas fa-times"></i> Mínimo 8 caracteres</li>
              <li id="req-upper"   class="text-danger"><i class="fas fa-times"></i> Al menos una mayúscula</li>
              <li id="req-num"     class="text-danger"><i class="fas fa-times"></i> Al menos un número</li>
              <li id="req-special" class="text-danger"><i class="fas fa-times"></i> Al menos un carácter especial (!@#$%...)</li>
            </ul>
          </div>

          <div class="row">
            <div class="col-12">
              <button type="submit" class="btn btn-primary btn-block">
                <i class="fas fa-key"></i> Cambiar contraseña
              </button>
            </div>
          </div>

        {{ form_end(form) }}

        <p class="mt-3 mb-0 text-center">
          <a href="{{ path('app_logout') }}" class="text-muted">
            <i class="fas fa-sign-out-alt"></i> Cerrar sesión
          </a>
        </p>

      </div>
    </div>
  </div>

  <script>
    document.querySelectorAll('.toggle-pwd').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var input = this.closest('.input-group').querySelector('input');
        var icon  = this.querySelector('i');
        if (input.type === 'password') {
          input.type     = 'text';
          icon.className = 'fas fa-eye-slash';
        } else {
          input.type     = 'password';
          icon.className = 'fas fa-eye';
        }
      });
    });

    function checkRequisito(id, cumple) {
      var el = document.getElementById(id);
      if (cumple) {
        el.className = 'text-success';
        el.querySelector('i').className = 'fas fa-check';
      } else {
        el.className = 'text-danger';
        el.querySelector('i').className = 'fas fa-times';
      }
    }

    var pwdPrincipal = document.querySelector('.pwd-principal');
    if (pwdPrincipal) {
      pwdPrincipal.addEventListener('input', function () {
        var val = this.value;
        checkRequisito('req-len',     val.length >= 8);
        checkRequisito('req-upper',   /[A-Z]/.test(val));
        checkRequisito('req-num',     /\d/.test(val));
        checkRequisito('req-special', /[^a-zA-Z0-9]/.test(val));
      });
    }
  </script>
</body>
</html>
