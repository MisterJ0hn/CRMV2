<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-Compatible" content="IE=edge">
  <title>Contraseña Caducada</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/build/adminlte/plugins/fontawesome-free/css/all.min.css">
  <link rel="stylesheet" href="/build/adminlte/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
  <link rel="stylesheet" href="/build/adminlte/dist/css/adminlte.min.css">
  <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700" rel="stylesheet">
</head>
<body class="hold-transition login-page">
  <div class="login-box">
    <div class="login-logo">
      <b>Mi</b> CRM
    </div>

    <div class="card">
      <div class="card-body login-card-body">

        <div class="text-center mb-3">
          <i class="fas fa-lock fa-3x text-warning"></i>
        </div>

        <p class="login-box-msg">
          <strong>Tu contraseña ha caducado.</strong><br>
          Por seguridad debes establecer una nueva contraseña.<br>
          Haz clic en el botón para recibir un enlace de cambio en tu correo:
        </p>

        {% if error is not null %}
          <div class="alert alert-danger">{{ error }}</div>
        {% endif %}

        <div class="text-center mb-3">
          <span class="text-muted">
            <i class="fas fa-envelope"></i> {{ correo }}
          </span>
        </div>

        <form action="{{ path('password_caducado') }}" method="post">
          <div class="row">
            <div class="col-12">
              <button type="submit" class="btn btn-warning btn-block">
                <i class="fas fa-paper-plane"></i> Enviar enlace de cambio de contraseña
              </button>
            </div>
          </div>
        </form>

        <p class="mt-3 mb-1 text-center">
          <small class="text-muted">
            Recibirás un correo en <strong>{{ correo }}</strong> con las instrucciones.<br>
            El enlace tendrá una vigencia limitada.
          </small>
        </p>

      </div>
    </div>
  </div>
</body>
</html>
