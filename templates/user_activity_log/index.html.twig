{% extends 'base.html.twig' %}

{% block title %}Log de Actividad de Usuarios{% endblock %}

{% block body %}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0 text-dark"><i class="fas fa-history mr-2"></i>Log de Actividad</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Inicio</a></li>
                    <li class="breadcrumb-item active">Log de Actividad</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
<div class="container-fluid">

    {# ── Filtros ── #}
    <div class="card card-outline card-primary">
        <div class="card-header">
            <h3 class="card-title"><i class="fas fa-filter mr-1"></i> Filtros</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-card-widget="collapse">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            <form method="GET" action="{{ path('user_activity_log_index') }}" id="filtroForm">
                <div class="row">

                    {# Fecha Desde #}
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Desde</label>
                            <input type="date" class="form-control" name="desde"
                                   value="{{ filtros.desde }}">
                        </div>
                    </div>

                    {# Fecha Hasta #}
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Hasta</label>
                            <input type="date" class="form-control" name="hasta"
                                   value="{{ filtros.hasta }}">
                        </div>
                    </div>

                    {# Usuario (Select2 con búsqueda) #}
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Usuario</label>
                            <select class="form-control select2" name="usuario" id="selectUsuario"
                                    style="width:100%">
                                <option value="">-- Todos --</option>
                                {% for u in usuarios %}
                                    <option value="{{ u.id }}"
                                        {% if filtros.usuario == u.id %}selected{% endif %}>
                                        {{ u.nombre }} ({{ u.username }})
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    {# Módulo #}
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Módulo</label>
                            <select class="form-control select2" name="modulo" id="selectModulo"
                                    style="width:100%">
                                <option value="">-- Todos --</option>
                                {% for m in modulos %}
                                    <option value="{{ m }}"
                                        {% if filtros.modulo == m %}selected{% endif %}>
                                        {{ m }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    {# Botones #}
                    <div class="col-md-1 d-flex align-items-end">
                        <div class="form-group w-100">
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>

                </div>
            </form>
        </div>
    </div>

    {# ── Resultados ── #}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-list mr-1"></i>
                Registros encontrados: <strong>{{ logs|length }}</strong>
            </h3>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-striped table-hover table-bordered" id="tablaLogs">
                <thead>
                    <tr>
                        <th style="width:140px">Fecha / Hora</th>
                        <th>Usuario</th>
                        <th style="width:60px">Método</th>
                        <th>Ruta</th>
                        <th>Módulo</th>
                        <th style="width:60px">Estado</th>
                        <th style="width:100px">IP</th>
                        <th>Ubicación</th>
                    </tr>
                </thead>
                <tbody>
                {% for log in logs %}
                    <tr>
                        <td class="text-nowrap">
                            {{ log.fechaRegistro|date('Y-m-d H:i:s') }}
                        </td>
                        <td>
                            {% if log.usuario %}
                                <span class="badge badge-secondary">{{ log.usuario.username }}</span>
                                {{ log.usuario.nombre }}
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>
                            {% set metodo = log.metodo %}
                            {% if metodo == 'GET' %}
                                <span class="badge badge-info">GET</span>
                            {% elseif metodo == 'POST' %}
                                <span class="badge badge-success">POST</span>
                            {% elseif metodo == 'PUT' or metodo == 'PATCH' %}
                                <span class="badge badge-warning">{{ metodo }}</span>
                            {% elseif metodo == 'DELETE' %}
                                <span class="badge badge-danger">DELETE</span>
                            {% else %}
                                <span class="badge badge-light">{{ metodo }}</span>
                            {% endif %}
                        </td>
                        <td class="text-break" style="max-width:260px">
                            <small>{{ log.ruta }}</small>
                        </td>
                        <td>
                            {% if log.controlador %}
                                {% set modLabel = log.controlador|split('\\')|last|split('::')|first|replace({'Controller':''}) %}
                                <span class="badge badge-primary">{{ modLabel }}</span>
                                <small class="text-muted">
                                    {{ log.controlador|split('::')|last}}
                                </small>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            {% set code = log.statusCode %}
                            {% if code >= 200 and code < 300 %}
                                <span class="badge badge-success">{{ code }}</span>
                            {% elseif code >= 300 and code < 400 %}
                                <span class="badge badge-info">{{ code }}</span>
                            {% elseif code >= 400 and code < 500 %}
                                <span class="badge badge-warning">{{ code }}</span>
                            {% elseif code >= 500 %}
                                <span class="badge badge-danger">{{ code }}</span>
                            {% else %}
                                <span class="badge badge-secondary">{{ code }}</span>
                            {% endif %}
                        </td>
                        <td><small>{{ log.ip }}</small></td>
                        <td>
                            {% if log.latitud and log.longitud %}
                                <a href="https://www.google.com/maps?q={{ log.latitud }},{{ log.longitud }}"
                                   target="_blank" rel="noopener"
                                   title="{{ log.latitud }}, {{ log.longitud }}">
                                    <i class="fas fa-map-marker-alt text-danger mr-1"></i>
                                    {% if log.ciudad %}{{ log.ciudad }}{% endif %}
                                    {% if log.pais %}<small class="text-muted">({{ log.pais }})</small>{% endif %}
                                </a>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted py-3">
                            <i class="fas fa-inbox mr-1"></i> Sin registros para los filtros seleccionados.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="card-footer">
            <div class="navigation">
                {{ knp_pagination_render(logs,'@KnpPaginator/Pagination/twitter_bootstrap_v4_pagination.html.twig',{},{
                'position': 'centered',
                'rounded': true,
                }) }}
            </div>
        </div>
    </div>

</div>
</section>

<script>
$(function () {
    $('#selectUsuario, #selectModulo').select2({
        theme: 'bootstrap4',
        placeholder: '-- Seleccione --',
        allowClear: true,
        language: {
            noResults: function () { return 'Sin resultados'; },
            searching: function () { return 'Buscando...'; }
        }
    });
});
</script>
{% endblock %}
