{% extends 'base.html.twig' %}

{% block title %}Log de Actividad de Usuarios{% endblock %}

{% block body %}
<style>
    .skeleton-row td {
        padding: 0.5rem 0.75rem;
    }
    .skeleton-cell {
        background: linear-gradient(90deg, #e9ecef 25%, #dee2e6 50%, #e9ecef 75%);
        background-size: 200% 100%;
        animation: skeleton-shimmer 1.4s infinite;
        border-radius: 4px;
        display: inline-block;
        height: 16px;
    }
    @keyframes skeleton-shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
</style>

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0 text-dark"><i class="fas fa-history mr-2"></i>Log de Actividad</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Inicio</a></li>
                    <li class="breadcrumb-item active">Log de Actividad</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
<div class="container-fluid">

    {# ── Filtros ── #}
    <div class="card card-outline card-primary">
        <div class="card-header">
            <h3 class="card-title"><i class="fas fa-filter mr-1"></i> Filtros</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-card-widget="collapse">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            <form id="filtroForm">
                <div class="row">

                    {# Fecha Desde #}
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Desde</label>
                            <input type="date" class="form-control" name="desde"
                                   value="{{ "now"|date("Y-m-d") }}">
                        </div>
                    </div>

                    {# Fecha Hasta #}
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Hasta</label>
                            <input type="date" class="form-control" name="hasta"
                                   value="{{ "now"|date("Y-m-d") }}">
                        </div>
                    </div>

                    {# Perfil de usuario #}
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Perfil</label>
                            <select class="form-control select2" name="perfil" id="selectPerfil" style="width:100%">
                                <option value="">-- Todos --</option>
                                {% for p in perfiles %}
                                    <option value="{{ p.id }}">{{ p.nombre }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    {# Usuario #}
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Usuario</label>
                            <select class="form-control" name="usuario" id="selectUsuario" style="width:100%">
                                <option value="">-- Todos --</option>
                                {% for u in usuarios %}
                                    <option value="{{ u.id }}"
                                            data-perfil="{{ u.usuarioTipo ? u.usuarioTipo.id : '' }}">
                                        {{ u.nombre }} ({{ u.username }})
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    {# Módulo #}
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Módulo</label>
                            <select class="form-control select2" name="modulo" id="selectModulo" style="width:100%">
                                <option value="">-- Todos --</option>
                                {% for m in modulos %}
                                    <option value="{{ m }}">{{ m }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    {# Botones #}
                    <div class="col-md-1 d-flex align-items-end">
                        <div class="form-group w-100">
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>

                </div>
            </form>
        </div>
    </div>

    {# ── Resultados ── #}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title" id="tituloResultados">
                <i class="fas fa-list mr-1"></i>
                <span id="contadorRegistros">Cargando...</span>
            </h3>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-striped table-hover table-bordered" id="tablaLogs">
                <thead>
                    <tr>
                        <th style="width:140px">Fecha / Hora</th>
                        <th>Usuario</th>
                        <th style="width:60px">Método</th>
                        <th>Ruta</th>
                        <th>Módulo</th>
                        <th style="width:60px">Estado</th>
                        <th style="width:100px">IP</th>
                        <th>Ubicación</th>
                    </tr>
                </thead>

                {# Skeleton inicial #}
                <tbody id="logsBody">
                    {% for i in 1..8 %}
                    <tr class="skeleton-row">
                        <td><span class="skeleton-cell" style="width:110px"></span></td>
                        <td><span class="skeleton-cell" style="width:{{ 80 + (i * 13) % 60 }}px"></span></td>
                        <td><span class="skeleton-cell" style="width:40px"></span></td>
                        <td><span class="skeleton-cell" style="width:{{ 120 + (i * 23) % 80 }}px"></span></td>
                        <td><span class="skeleton-cell" style="width:70px"></span></td>
                        <td><span class="skeleton-cell" style="width:35px"></span></td>
                        <td><span class="skeleton-cell" style="width:80px"></span></td>
                        <td><span class="skeleton-cell" style="width:60px"></span></td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot id="logsPagination"></tfoot>
            </table>
        </div>
    </div>

</div>
</section>

<script>
$(function () {
    var dataUrl = '{{ path("user_activity_log_data") }}';

    var s2opts = {
        theme: 'bootstrap4',
        placeholder: '-- Todos --',
        allowClear: true,
        language: {
            noResults:  function () { return 'Sin resultados'; },
            searching:  function () { return 'Buscando...'; }
        }
    };

    // Todos los usuarios para filtrado por perfil
    var allUsers = [];
    $('#selectUsuario option[value!=""]').each(function () {
        allUsers.push({ id: $(this).val(), text: $(this).text(), perfil: $(this).data('perfil') });
    });

    function buildUsuarioSelect(perfilId, selectedId) {
        if ($('#selectUsuario').data('select2')) {
            $('#selectUsuario').select2('destroy');
        }
        $('#selectUsuario').empty().append('<option value="">-- Todos --</option>');
        $.each(allUsers, function (_, u) {
            if (!perfilId || String(u.perfil) === String(perfilId)) {
                var opt = $('<option>', { value: u.id, text: u.text });
                if (selectedId && String(u.id) === String(selectedId)) {
                    opt.prop('selected', true);
                }
                $('#selectUsuario').append(opt);
            }
        });
        $('#selectUsuario').select2(s2opts);
    }

    buildUsuarioSelect('', '');
    $('#selectPerfil, #selectModulo').select2(s2opts);

    $('#selectPerfil').on('change', function () {
        buildUsuarioSelect($(this).val(), null);
    });

    // ── Skeleton ──
    function showSkeleton() {
        var rows = '';
        for (var i = 1; i <= 8; i++) {
            rows += '<tr class="skeleton-row">' +
                '<td><span class="skeleton-cell" style="width:110px"></span></td>' +
                '<td><span class="skeleton-cell" style="width:' + (80 + (i * 13) % 60) + 'px"></span></td>' +
                '<td><span class="skeleton-cell" style="width:40px"></span></td>' +
                '<td><span class="skeleton-cell" style="width:' + (120 + (i * 23) % 80) + 'px"></span></td>' +
                '<td><span class="skeleton-cell" style="width:70px"></span></td>' +
                '<td><span class="skeleton-cell" style="width:35px"></span></td>' +
                '<td><span class="skeleton-cell" style="width:80px"></span></td>' +
                '<td><span class="skeleton-cell" style="width:60px"></span></td>' +
                '</tr>';
        }
        $('#logsBody').html(rows);
        $('#logsPagination').empty();
        $('#contadorRegistros').html('Cargando...');
    }

    // ── Cargar datos ──
    function cargarDatos(params) {
        showSkeleton();

        $.get(dataUrl, params)
            .done(function (html) {
                var $parsed   = $(html);
                var $tbody    = $parsed.filter('tbody');
                var $tfoot    = $parsed.filter('tfoot');

                $('#logsBody').replaceWith($tbody);
                $('#logsPagination').replaceWith($tfoot);

                // Actualizar contador
                var total = $tfoot.find('strong').first().text();
                if (total) {
                    $('#contadorRegistros').html('Registros encontrados: <strong>' + total + '</strong>');
                } else {
                    var filas = $tbody.find('tr').length;
                    $('#contadorRegistros').html('Registros encontrados: <strong>' + filas + '</strong>');
                }

                // Vincular clics de paginación
                bindPaginacionAjax();
            })
            .fail(function () {
                $('#logsBody').html('<tr><td colspan="8" class="text-center text-danger py-3">' +
                    '<i class="fas fa-exclamation-triangle mr-1"></i> Error al cargar los datos.</td></tr>');
                $('#contadorRegistros').text('Error al cargar');
            });
        
        
    }

    function bindPaginacionAjax() {
        $('#logsPagination').find('a.page-link').on('click', function (e) {
            e.preventDefault();
            var href   = $(this).attr('href');
            var params = {};
            var query  = href.split('?')[1] || '';
            query.split('&').forEach(function (pair) {
                var kv = pair.split('=');
                if (kv[0]) params[decodeURIComponent(kv[0])] = decodeURIComponent(kv[1] || '');
            });
            // Combinar con filtros actuales del form
            var formParams = {};
            $('#filtroForm').serializeArray().forEach(function (f) { formParams[f.name] = f.value; });
            cargarDatos($.extend({}, formParams, { page: params.page || 1 }));
            $('html, body').animate({ scrollTop: $('#tablaLogs').offset().top - 20 }, 300);
        });
    }

    // ── Submit del form ──
    $('#filtroForm').on('submit', function (e) {
        e.preventDefault();
        var params = {};
        $(this).serializeArray().forEach(function (f) { params[f.name] = f.value; });
        params.page = 1;
        cargarDatos(params);
        $(".btn-block").prop("disabled",false);
    });

    // Carga inicial con fecha de hoy
    cargarDatos({
        desde: $('[name="desde"]').val(),
        hasta: $('[name="hasta"]').val(),
        page:  1
    });
});
</script>
{% endblock %}
