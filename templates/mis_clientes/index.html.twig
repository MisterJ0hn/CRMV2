{% extends 'base_dark.html.twig' %}

{% block title %}Mis Clientes{% endblock %}

{% block body %}


    <div class="card mc-dark-card">
        <div class="col-sm-6">
            <div class="row">
                <h3 >Mis Clientes</h3>  <h1 class="total-clientes mc-dark-title-total" id="total-clientes"></h1> <h1 class="total-casos mc-dark-title-total" id="total-casos"></h1>
            </div>
        </div>
    </div>

    <div class="card mc-dark-page">
        <div class="card-header">
            <div class="row align-items-center">
                
                <div class="col-md-3">
                    <input type="text"
                        id="bFiltro"
                        class="form-control"
                        placeholder="Buscar por nombre, RUT o folio..."
                        value="{{ bFiltro }}">
                </div>
                <div class="col-sm-12 col-md-3">
                    <input type="text" class="form-control" name="bFecha" id="bFecha"  value="" >
                </div>
                <div class="col-sm-12 col-md-1"> 
                    <button class="btn btn-primary" id="btn-buscar" type="button">
                        <i class="fas fa-search"></i>
                    </button> 
                </div>
                


            </div>
            <div class="row align-items-center mt-2">
                <div class="col-md-2">
                    {% if materias is not empty %}
                        <select id="bMateria" class="form-control  d-inline-block" >
                            <option value="0">Materia</option>
                            {% for materia in materias %}
                                <option value="{{ materia.id }}">{{ materia.nombre }}</option>
                            {% endfor %}
                        </select>
                    {% endif %}
                </div>
                <div class="col-md-2">                        
                    <select id="bServicio" class="form-control  d-inline-block" >
                        <option value="0" default>Servicios</option>
                       
                    </select>                      
                </div>
                <div class="col-md-2">
                    <select id="bTramitador" class="form-control  d-inline-block" >
                        <option value="0">Tramitador</option>
                    </select>
                </div>
                <div class="col-md-1">                        
                    <select id="bAtrasado" class="form-control  d-inline-block" >
                        <option value="0" default>Pago</option>
                        <option value="1">Atrasado</option>
                        <option value="2">Al Día</option>
                    </select>                      
                </div>
                <div class="col-md-1">                        
                    <select id="bTipoCliente" class="form-control  d-inline-block" >
                        <option value="0" default>Cliente</option>
                        <option value="1">VIP</option>
                        <option value="2">NORMAL</option>
                    </select>                      
                </div>
                <div class="col-md-1">                        
                    <select id="bPrioridad" class="form-control  d-inline-block" >
                        <option value="0" default>Prioridad</option>
                        <option value="1">Urgente</option>
                        <option value="2">Media</option>
                        <option value="3">Normal</option>
                    </select>                      
                </div>
                <div class="col-md-1">                        
                    <select id="bPrimerPago" class="form-control  d-inline-block" >
                        <option value="0" default>Cuota 1</option>
                        <option value="1">Pagada</option>
                        <option value="2">No Pagada</option>                        
                    </select>                      
                </div>
                <div class="col-md-1">
                    <button id="btn-limpiar" type="button" class="btn btn-dark bg-light">Limpiar</button>
                </div>
            </div>
        </div>

        <div id="resultado">
            <div class="text-center py-5">
                <i class="fas fa-spinner fa-spin fa-2x text-primary"></i>
            </div>
        </div>
    </div>


<div class="modal fade" id="modalObservacion" tabindex="-1" aria-labelledby="modalObservacion" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content bg-dark text-light">
      <div class="modal-header">
        <h5 class="modal-title" id="modalObservacion">Recordatorio</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div id="contenidoObservacion">
            
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
$('#bFecha').daterangepicker({
     "showDropdowns": true,
    "drops": "down",
    "startDate":"{{dateInicio}}",
    "endDate": "{{dateFin}}",
    "locale": {
        "format": "YYYY-MM-DD",
        "applyLabel": "Apply",
        "cancelLabel": "Cancel",
    }
}, function(start, end, label) {
    console.log('New date range selected: ' + start.format('YYYY-MM-DD') + ' to ' + end.format('YYYY-MM-DD'));
});
var _filtrosActuales = '';

function cargarFiltrosPorMateria(materiaId) {
    $.ajax({
        url: '/mis_clientes/filtros_por_materia?materia=' + materiaId,
        type: 'GET',
        dataType: 'json',
        success: function(data) {
            var $servicio    = $('#bServicio');
            var $tramitador  = $('#bTramitador');
            var servicioVal  = $servicio.val();
            var tramitadorVal = $tramitador.val();

            $servicio.empty().append('<option value="0">Servicios</option>');
            $.each(data.servicios, function(i, s) {
                $servicio.append('<option value="' + s.id + '">' + s.nombre + '</option>');
            });
            if ($servicio.find('option[value="' + servicioVal + '"]').length) {
                $servicio.val(servicioVal);
            }

            $tramitador.empty().append('<option value="0">Tramitador</option>');
            $.each(data.tramitadores, function(i, t) {
                $tramitador.append('<option value="' + t.id + '">' + t.nombre + '</option>');
            });
            if ($tramitador.find('option[value="' + tramitadorVal + '"]').length) {
                $tramitador.val(tramitadorVal);
            }
        }
    });
}

function cargarClientes(url,urlTotal) {
    $('#resultado').html('<div class="text-center py-5"><i class="fas fa-spinner fa-spin fa-2x text-primary"></i></div>');
    $('#total-casos').html('');
    $('#total-clientes').html('');
    $.ajax({
        url: url,
        type: 'GET',
        dataType: 'json',
        success: function(data) {
            if (data.error) {
                $('#resultado').html('<div class="alert alert-danger m-3">' + data.error + '</div>');
                return;
            }
            $('#resultado').html(data.html);
            $('#total-clientes').html(' ' + data.total_formateado.toLocaleString() + ' clientes ');
            $.ajax({
                url: urlTotal,
                type: 'GET',
                dataType: 'json',
            
                success: function(data2) {
                    
                    //$('#total-casos').html(' |  ' + data2.total.toLocaleString() + ' causas activas ');
                    
                },error: function() {
                    $('#total-casos').html('');
                }
            });           
        },
        error: function() {
            $('#resultado').html('<div class="alert alert-danger m-3">Error al cargar los datos.</div>');
        }
    });
}

$(document).ready(function() {
    cargarFiltrosPorMateria(0);
    cargarClientes('/mis_clientes/obtenerContenido', '/mis_clientes/obtenerTotal');
});

function buildFiltros() {
    var filtro   = $('#bFiltro').val();
    var compania = $('#bCompania').val() || 0;
    var materia = $('#bMateria').val() || 0;
    var servicio = $('#bServicio').val() || 0;
    var atrasado = $('#bAtrasado').val() || 0;
    var tramitador = $('#bTramitador').val() || 0;
    var tipoCliente = $('#bTipoCliente').val() || 0;
    var prioridad = $('#bPrioridad').val() || 0;
    var primerPago = $('#bPrimerPago').val() || 0;
    var fecha = $('#bFecha').val();

    return 'bFiltro=' + encodeURIComponent(filtro) +
            '&bCompania=' + compania +
            '&bMateria=' + materia +
            '&bServicio=' + servicio +
            '&bAtrasado=' + atrasado +
            '&bTramitador=' + tramitador +
            '&bTipoCliente=' + tipoCliente +
            '&bPrioridad=' + prioridad +
            '&bPrimerPago=' + primerPago +
            '&bFecha=' + fecha;
}

$('#btn-buscar').on('click', function() {
    _filtrosActuales = buildFiltros();
    url = '/mis_clientes/obtenerContenido?' + _filtrosActuales;
    urlTotal = '/mis_clientes/obtenerTotal?' + _filtrosActuales;
    cargarClientes(url, urlTotal);
});

$('#bFiltro').on('keypress', function(e) {
    if (e.which === 13) { $('#btn-buscar').click(); }
});

$('#bMateria').on('change', function() {
    $('#bServicio').val('0');
    cargarFiltrosPorMateria($(this).val());
    _filtrosActuales = buildFiltros();
    cargarClientes('/mis_clientes/obtenerContenido?' + _filtrosActuales, '/mis_clientes/obtenerTotal?' + _filtrosActuales);
});

$('#bServicio').on('change', function() {
    _filtrosActuales = buildFiltros();
    cargarClientes('/mis_clientes/obtenerContenido?' + _filtrosActuales, '/mis_clientes/obtenerTotal?' + _filtrosActuales);
});

$('#bAtrasado').on('change', function() {
    _filtrosActuales = buildFiltros();
    cargarClientes('/mis_clientes/obtenerContenido?' + _filtrosActuales, '/mis_clientes/obtenerTotal?' + _filtrosActuales);
});
$('#bTipoCliente').on('change', function() {
    _filtrosActuales = buildFiltros();
    cargarClientes('/mis_clientes/obtenerContenido?' + _filtrosActuales, '/mis_clientes/obtenerTotal?' + _filtrosActuales);
});
$('#bTramitador').on('change', function() {
    _filtrosActuales = buildFiltros();
    cargarClientes('/mis_clientes/obtenerContenido?' + _filtrosActuales, '/mis_clientes/obtenerTotal?' + _filtrosActuales);
});
$('#bPrioridad').on('change', function() {
    _filtrosActuales = buildFiltros();
    cargarClientes('/mis_clientes/obtenerContenido?' + _filtrosActuales, '/mis_clientes/obtenerTotal?' + _filtrosActuales);
});
$('#bPrimerPago').on('change', function() {
    _filtrosActuales = buildFiltros();
    cargarClientes('/mis_clientes/obtenerContenido?' + _filtrosActuales, '/mis_clientes/obtenerTotal?' + _filtrosActuales);
});
$('#bFecha').on('change', function() {
    _filtrosActuales = buildFiltros();
     cargarClientes('/mis_clientes/obtenerContenido?' + _filtrosActuales, '/mis_clientes/obtenerTotal?' + _filtrosActuales);
});


$('#btn-limpiar').on('click', function() {
    $('#bFiltro').val('');
    if ($('#bMateria').length) { $('#bMateria').val('0'); }
    if ($('#bServicio').length) { $('#bServicio').val('0'); }
    if ($('#bAtrasado').length) { $('#bAtrasado').val('0'); }
    if ($('#bTipoCliente').length) { $('#bTipoCliente').val('0'); }
    if ($('#bTramitador').length) { $('#bTramitador').val('0'); }
    if ($('#bPrioridad').length) { $('#bPrioridad').val('0'); }
    if ($('#bPrimerPago').length) { $('#bPrimerPago').val('0'); }
    cargarFiltrosPorMateria(0);
    _filtrosActuales = '';
    cargarClientes('/mis_clientes/obtenerContenido', '/mis_clientes/obtenerTotal');
});

$(document).on('click', '#resultado a.page-link, #resultado th a', function(e) {
    e.preventDefault();
    var url = $(this).attr('href');
    var urlTotal = "/mis_clientes/obtenerTotal?" + _filtrosActuales;
    if (url && url !== '#') {
        if (_filtrosActuales && url.indexOf('bFiltro') === -1) {
            url += (url.indexOf('?') === -1 ? '?' : '&') + _filtrosActuales;
           
         
        }
        cargarClientes(url,urlTotal);
    }
});

$('#modalObservacion').on('show.bs.modal', function (event) {
  var button = $(event.relatedTarget) // Button that triggered the modal
  var id = button.data('mensaje-id') // Extract info from data-* attributes
  // If necessary, you could initiate an AJAX request here (and then do the updating in a callback).
  // Update the modal's content. We'll use jQuery here, but you could use a data binding library or other methods instead.
  var modal = $(this)

    $.ajax({
            url: '/mensaje/'+id+'/obtener_mensaje',
            type: 'GET',
            dataType: 'json',
            success: function(data) {
                if (data.error) {
                    modal.find('#contenidoObservacion').html('<div class="alert alert-danger m-3">' + data.error + '</div>');
                    return;
                }
                modal.find('#contenidoObservacion').html('<p>' + data.mensaje + '</p>');
            },
            error: function() {
                modal.find('#contenidoObservacion').html('<div class="alert alert-danger m-3">Error al cargar los datos.</div>');
            }
        });
})
</script>

{% endblock %}
