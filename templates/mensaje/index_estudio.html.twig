{% extends 'base_dark.html.twig' %}


{% block title %}Mensaje index{% endblock %}

{% block body %}
     
    <div class="card bg-dark">   

        <div class="card-header ">
            <div class="row">                                        
                <div class="col-sm-12 col-md-4">
                    <input type="text" class="form-control" name="bFecha" id="bFecha"  value="" >
                </div>
                <div class="col-sm-12 col-md-1">
                    <button class="btn btn-primary btn-buscar" id="btn-buscar"><i class="fas fa-search"></i></button>
                </div>
                
                <!--<div class="col-sm-12 col-md-4 border-1">
                    <div class="row">
                        <div class="col">
                            <input type="text" class="form-control" name="bFecha" id="bFecha"  value="" >
                        </div>
                        <div class="col-sm-12 col-md-1">
                            <button type="button"  class="btn btn-secondary exportarxslx"><i class="fas fa-download"></i></button>
                        </div>
                    </div>
                </div>-->
                
            </div>
            <div class="row align-items-center mt-2">
                <div class="col-sm-12 col-md-2">
                    
                    <select name="bPrioridad" id="bPrioridad" class="form-control">
                        <option value="0">Prioridad</option>
                        {% for prioridad in prioridades %}
                            
                        <option value={{prioridad.id}} {% if prioridad.id == bPrioridad %}
                            selected
                        {% endif %}>{{prioridad.nombre}}</option>
                        {% endfor %}

                    </select>
                </div>
                <div class="col-sm-12 col-md-2">
                    <select class="form-control" disabled>
                        <option value="0">Tramitador</option>                            
                    </select>
                </div>
                <div class="col-sm-12 col-md-2">                       
                    <select name="bUsuarioDestino" id="bUsuarioDestino" class="form-control">
                        <option value="0">Usuario Destino</option>
                        {% for usuario in usuarios %}                                
                        <option value={{usuario.id}} {% if usuario.id == bUsuarioDestino %}
                            selected
                        {% endif %}>{{usuario.nombre}}</option>
                        {% endfor %}

                    </select>
                </div>
                <div class="col-sm-12 col-md-2">
                    
                    <select name="bEstado" id="bEstado" class="form-control bEstado">
                        <option value="0">Estado</option>
                        <option value="1">Pendiente</option>
                        <option value="2">Finalizado</option>
                        

                    </select>
                </div>
                <div class="col-md-1">
                    <button id="btn-limpiar" type="button" class="btn btn-dark bg-light">Limpiar</button>
                </div>
            </div>
            
        </div>
        <div class="card-body">
            <div id="resultado">
                <div class="text-center py-5">
                    <i class="fas fa-spinner fa-spin fa-2x text-primary"></i>
                </div>
            </div>
        </div>
    </div>

<script>
var _filtrosActuales = '';
$('#bFecha').daterangepicker({
           
            "drops": "down",
            "startDate":"{{dateInicio}}",
            "endDate": "{{dateFin}}",
            "locale": {
                "format": "YYYY-MM-DD",
                "applyLabel": "Apply",
                "cancelLabel": "Cancel",
            }
        }, function(start, end, label) {
        console.log('New date range selected: ' + start.format('YYYY-MM-DD') + ' to ' + end.format('YYYY-MM-DD') + ' (predefined range: ' + label + ')');
        
        });
function cargarClientes(url) {
    $('#resultado').html('<div class="text-center py-5"><i class="fas fa-spinner fa-spin fa-2x text-primary"></i></div>');
    $.ajax({
        url: url,
        type: 'GET',
        dataType: 'json',
        success: function(data) {
            if (data.error) {
                $('#resultado').html('<div class="alert alert-danger m-3">' + data.error + '</div>');
                return;
            }
            $('#resultado').html(data.html);
        },
        error: function() {
            $('#resultado').html('<div class="alert alert-danger m-3">Error al cargar los datos.</div>');
        }
    });
}

$(document).ready(function() {
    cargarClientes('/mensaje/obtenerContenidoEstudio');
});
function buildFiltros() {
    var fecha   = $('#bFecha').val();
    var prioridad = $('#bPrioridad').val() || 0;
    var estado = $('#bEstado').val() || '';
    var usuarioDestino = $('#bUsuarioDestino').val() || 0;
    
    return 'bFecha=' + fecha + '&bPrioridad=' + prioridad + '&bEstado=' + estado + '&bUsuarioDestino=' + usuarioDestino;
}

$('#bFecha').on('keypress', function(e) {
    if (e.which === 13) { $('#btn-buscar').click(); }
});

$('#btn-buscar').on('click', function() {
    _filtrosActuales = buildFiltros();
    url = '/mensaje/obtenerContenidoEstudio?' + _filtrosActuales;
    cargarClientes(url);
    $("button").prop('disabled', false);
});

$('#bPrioridad').on('change', function() {
    _filtrosActuales = buildFiltros();
    cargarClientes('/mensaje/obtenerContenidoEstudio?' + _filtrosActuales);
});
$('#bEstado').on('change', function() {
    _filtrosActuales = buildFiltros();
    cargarClientes('/mensaje/obtenerContenidoEstudio?' + _filtrosActuales);
});

$('#bUsuarioDestino').on('change', function() {
    _filtrosActuales = buildFiltros();
    cargarClientes('/mensaje/obtenerContenidoEstudio?' + _filtrosActuales);
});

$('#btn-limpiar').on('click', function() {
   
    if ($('#bPrioridad').length) { $('#bPrioridad').val('0'); }
    if ($('#bEstado').length) { $('#bEstado').val('0'); }
    if ($('#bUsuarioDestino').length) { $('#bUsuarioDestino').val('0'); }

    _filtrosActuales = '';
    cargarClientes('/mensaje/obtenerContenidoEstudio');
});

$(document).on('click', '#resultado a.page-link, #resultado th a', function(e) {
    e.preventDefault();
    var url = $(this).attr('href');
    if (url && url !== '#') {
        if (_filtrosActuales && url.indexOf('bFiltro') === -1) {
            url += (url.indexOf('?') === -1 ? '?' : '&') + _filtrosActuales;
        }
        cargarClientes(url);
    }
});

</script>
{% endblock %}
