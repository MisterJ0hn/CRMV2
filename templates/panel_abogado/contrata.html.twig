        $('.fecha-total').hide();
        $('.fecha-total-group').hide();
        
    });
    $('.primera-cuota').css("visibility", "hidden");
    

    
    

    function resumen(){

        if(validarOtrosCampos()){
            $("#pTotalContrato").html($.number($('.monto-contrato').val(), 0, ',', '.' ));
            $("#trCuotas").html("");
            $("#model_email").html($(".emailCliente").val());
            $("#model_nombre_cliente").html($(".txtNombre").val());
            var cuotas = parseInt($('.cuotas').val());
            var indiceStart = 1;
            var a = new Date();
            var diasPago=0;
            var sumames=0;
            $("#trCuotas").append('<tr><th>Cuota</th><th>Vencimiento</th><th>Monto</th></tr>');
            if ($('.chk-bono').is(':checked') || $('.chk-total').is(':checked') || $('.chk-incorporacion').is(':checked')) {
                if($('.chk-incorporacion').is(':checked')){
                    $("#trCuotas").append('<tr><td>'+indiceStart+'</td><td>'+$(".fecha-incorporacion").val()+'</td><td>$'+$.number($('.primera-cuota').val(), 0, ',', '.' )+'</td></tr>');
                }else if($('.chk-total').is(':checked')){
                    $("#trCuotas").append('<tr><td>'+indiceStart+'</td><td>'+$(".fecha-total").val()+'</td><td>$'+$.number($('.primera-cuota').val(), 0, ',', '.' )+'</td></tr>');
                    
                   
                }else{
                    $("#trCuotas").append('<tr><td>'+indiceStart+'</td><td>'+a.getFullYear()+'-'+((a.getMonth()+1)).toLocaleString('en-US', {minimumIntegerDigits: 2, useGrouping:false})+'-'+(a.getDate()).toLocaleString('en-US', {minimumIntegerDigits: 2, useGrouping:false})+'</td><td>$'+$.number($('.primera-cuota').val(), 0, ',', '.' )+'</td></tr>');    
                }
                indiceStart = indiceStart +1;
            }
            $(".chkDiasPago:checked").each(function(){
                a.setDate(this.value);
                diasPago=this.value;
            });

             if(diasPago == 0 && !$('.chk-total').is(':checked')){
                alert("Debe ingresar un dia de pago");
                return;
            }
            

            fechaPrimerPago=$('.primer-pago').val()+'-'+a.getDate();
            if(moment($('.primer-pago').val(), "YYYY-MM").daysInMonth()<30){
                if(diasPago==30){
                    fechaPrimerPago=$('.primer-pago').val()+'-28';
                }

            }else{
                
            }

            
            
            var datePrimerPago = new Date(fechaPrimerPago);
            var dateActual = new Date();

            if(dateActual.getTime()>=datePrimerPago.getTime()){
                sumames=1;
            }else{
                if($('.chk-incorporacion').is(':checked')){
                    if(datePrimerPago.getMonth()==dateActual.getMonth()){
                        sumames=1;
                    }
                }
            }
        
            
            // Construir fecha base usando año y mes del primer pago, sin mutar con setMonth/setDate
            // para evitar desbordamientos de mes cuando el día del pago es mayor que los días del mes destino
            var baseYear  = datePrimerPago.getFullYear();
            var baseMonth = datePrimerPago.getMonth(); // 0-based

            // Si sumames=1 significa que el primer pago ya pasó, arrancamos un mes antes
            // para que el primer ciclo del loop quede en el mes correcto
            var startMonth = baseMonth + sumames; // puede ser 0-based o adelantado 1 mes

            for (let i = indiceStart; i < cuotas + indiceStart; i++) {

                // Calcular el mes absoluto (0-based) para esta cuota
                var cuotaMonthOffset = startMonth + (i - indiceStart); // 0-based running month
                var cuotaYear  = baseYear + Math.floor(cuotaMonthOffset / 12);
                var cuotaMonth = cuotaMonthOffset % 12; // 0-based, siempre 0-11

                // Ajustar día de pago si el mes tiene menos días
                var maxDay = new Date(cuotaYear, cuotaMonth + 1, 0).getDate();
                var cuotaDay = Math.min(parseInt(diasPago), maxDay);

                var strYear  = cuotaYear.toString();
                var strMonth = (cuotaMonth + 1).toLocaleString('en-US', {minimumIntegerDigits: 2, useGrouping: false}); // 1-based
                var strDay   = cuotaDay.toLocaleString('en-US', {minimumIntegerDigits: 2, useGrouping: false});

                $("#trCuotas").append('<tr><td>'+i+'</td><td>'+strYear+'-'+strMonth+'-'+strDay+'</td><td>$'+$.number( $('.valor-cuota').val(), 0, ',', '.' )+'</td></tr>');
            }
            $("#contrata").modal("show");
        }
    }
    
