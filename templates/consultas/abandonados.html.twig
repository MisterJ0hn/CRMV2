{% extends 'base.html.twig' %}

{% block title %}Contratos Abandonados{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">Contratos Abandonados</h3>
    </div>
    <div class="card-body">
        <p class="text-muted">Contratos con morosidad &gt; 45 días que han tenido al menos un pago, creados en los últimos 24 meses.</p>
        <a href="{{ path('consultas_abandonados_excel') }}" class="btn btn-success">
            <i class="fas fa-download"></i> Descargar Excel
        </a>
    </div>
</div>
{% endblock %}
