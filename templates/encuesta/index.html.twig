{% extends 'base.html.twig' %}

{% block title %}Contrato index{% endblock %}

{% block body %}

<div class="row" id="resumenCards"></div>

<div id="resumenEncuestadores"></div>

<form action="" method="get" id="bForm">
    <input type="hidden" id="bStatus" name="bStatus" value="{{ bStatus ?? '' }}">
    {{ include('/cuadrosBusquedas/busquedaTicketsEncuestas.html.twig', {'TipoFiltro':TipoFiltro}) }}
</form>

<div id="tablaContratos">
    <div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x"></i></div>
</div>

<script>
    $('#bFecha').daterangepicker({
        "drops": "down",
        "startDate": "{{ dateInicio }}",
        "endDate": "{{ dateFin }}",
        "locale": {
            "format": "YYYY-MM-DD",
            "applyLabel": "Apply",
            "cancelLabel": "Cancel"
        }
    }, function(start, end) {
        $(".bFolio").val('');
    });

    $(".bFolio").change(function () { $(".bFiltro").val(''); });
    $(".bFiltro").change(function () { $(".bFolio").val(''); });

    function cargarTabla(extraParams) {
        var params = $('#bForm').serialize();
        if (extraParams) {
            params += '&' + $.param(extraParams);
        }
        $('#tablaContratos').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x"></i></div>');
        $.get('{{ path("encuesta_obtener_contenido") }}', params, function (data) {
            $('#tablaContratos').html(data.html);
            $("button").prop('disabled',false);
        });
        
    }

    function cargarResumen() {
        $.get('{{ path("encuesta_obtener_resumen") }}', $('#bForm').serialize(), function (data) {
            $('#resumenCards').html(data.html);
        });
    }

    function cargarEncuestadores() {
        var bFecha = $('#bFecha').val() || '{{ dateInicio }} - {{ dateFin }}';
        var partes = bFecha.split(' - ');
        $.get('{{ path("encuesta_obtener_resumen_encuestadores") }}', {
            fechainicio: partes[0] || '{{ dateInicio }}',
            fechafin:    partes[1] || '{{ dateFin }}',
            status:      $('#bStatus').val() || '',
            tipoFecha:   $('[name="bTipoFecha"]').val() || 0
        }, function (data) {
            $('#resumenEncuestadores').html(data);
             
        });
    }

    function buscar(status) {
        if (status !== undefined) {
            $('#bStatus').val(status);
        }
        $("button").prop('disabled', true);
        cargarResumen();
        cargarEncuestadores();
        cargarTabla();

       
       
    }

    $('#bForm').on('submit', function (e) {
        e.preventDefault();
        buscar();
        
    });

    // Intercept pagination and sort links in the table (they point back to obtenerContenido)
    $(document).on('click', '#tablaContratos a.page-link, #tablaContratos th a', function (e) {
        e.preventDefault();
        var href = $(this).attr('href');
        if (!href || href === '#') return;
        $('#tablaContratos').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x"></i></div>');
        $.get(href, function (data) {
            $('#tablaContratos').html(data.html);
        });
    });

    $(document).ready(function () {
        buscar();
    });
</script>

{% endblock %}
