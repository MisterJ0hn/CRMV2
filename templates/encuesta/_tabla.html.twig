<div class="card">
    <div class="card-header">
    </div>
    <div class="card-body table-responsive p-0" style="height: 500px;">
        <table class="table table-head-fixed text-nowrap table-striped table-sm">
            <thead>
                <tr>
                    <th>{{ knp_pagination_sortable(contratos, 'Compañia', 'agenda.cuenta') }} {% if contratos.isSorted('agenda.cuenta') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>{{ knp_pagination_sortable(contratos, 'Folio', 'folio') }} {% if contratos.isSorted('folio') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>{{ knp_pagination_sortable(contratos, 'AgendaId', 'agenda.id') }} {% if contratos.isSorted('agenda.id') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>{{ knp_pagination_sortable(contratos, 'Grupo', 'grupo.id') }} {% if contratos.isSorted('grupo.id') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>Calidad</th>
                    <th>{{ knp_pagination_sortable(contratos, 'Cliente', 'nombre') }} {% if contratos.isSorted('nombre') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>{{ knp_pagination_sortable(contratos, 'Fecha Contrato', 'fechaCreacion') }} {% if contratos.isSorted('fechaCreacion') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>{{ knp_pagination_sortable(contratos, 'Fecha Ult. Encuesta', 'fechaEncuesta') }} {% if contratos.isSorted('fechaEncuesta') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>{{ knp_pagination_sortable(contratos, 'Fecha Ult. Gestión', 'fechaGestion') }} {% if contratos.isSorted('fechaGestion') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>{{ knp_pagination_sortable(contratos, 'Q. Encuesta', 'qtyEncuesta') }} {% if contratos.isSorted('qtyEncuesta') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>{{ knp_pagination_sortable(contratos, 'Q. Gestión', 'qtyGestionEncuesta') }} {% if contratos.isSorted('qtyGestionEncuesta') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>Días Mora</th>
                    <th>C.Pgda</th>
                    <th>{{ knp_pagination_sortable(contratos, 'Ultima Nota', 'ultimaNota') }} {% if contratos.isSorted('ultimaNota') %} <i class="fas fa-sort"></i>{% endif %}</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
            {% for contrato in contratos %}
                <tr>
                    <td>{{contrato.agenda.cuenta.nombre}}</td>
                    <td>{{ contrato.folio }}</td>
                    <td>{{ contrato.agenda.id }}</td>
                    <td>{{ contrato.grupo?contrato.grupo.id:'' }}</td>
                    <td>
                    {% if contrato.grupo.usuarioGrupos is defined %}
                        {% for usuarioGrupo in contrato.grupo.usuarioGrupos %}
                            {{usuarioGrupo.usuario}}
                        {% endfor %}
                    {% endif %}
                    </td>
                    <td>{{ contrato.nombre }}</td>
                    <td>{{ contrato.fechaCreacion|date('d-m-Y H:i') }}</td>
                    <td align="center">{{ contrato.fechaEncuesta?contrato.fechaEncuesta|date('d-m-Y H:i') : '' }}</td>
                    <td align="center">{{ contrato.fechaGestion?contrato.fechaGestion|date('d-m-Y H:i') : '' }}</td>
                    <td align="center">{{ contrato.qtyEncuesta?contrato.qtyEncuesta:0  }}</td>
                    <td align="center">{{ contrato.qtyGestionEncuesta?contrato.qtyGestionEncuesta:0  }}</td>
                    <td>
                    {% set cuotaUtilizado = 0 %}
                    {% for cuota in contrato.detalleCuotas %}
                        {% if cuotaUtilizado == 0 %}
                            {% if cuota.anular is null %}
                                {% if cuota.monto > cuota.pagado %}
                                    {{ diasmora(cuota.fechaPago|date('Y-m-d'))<0?0:diasmora(cuota.fechaPago() |date('Y-m-d'))}} dias
                                    {% set cuotaUtilizado = 1 %}
                                {% endif %}
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                    </td>
                    <td align="center">{{ totalesCobranza(contrato.id) }}</td>
                    <td align="center">{{ contrato.ultimaNota?contrato.ultimaNota:''}}</td>
                    <td>
                        <div class="btn-group btn-group-sm" role="group">
                            <a href="{{path('encuesta_grupo',{'id':contrato.id})}}" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a href="{{path('encuesta_ver_encuestas',{'id':contrato.id})}}" class="btn btn-sm btn-success"><i class="fas fa-eye"></i></a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="15">No hay contratos</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="card-footer">
        <div class="card-footer clearfix">
            <div class="navigation">
                {{ knp_pagination_render(contratos,'@KnpPaginator/Pagination/twitter_bootstrap_v4_pagination.html.twig',{},{
                'position': 'centered',
                'rounded': true,
                }) }}
            </div>
        </div>
    </div>
</div>
