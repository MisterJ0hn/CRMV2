{% extends 'base.html.twig' %}

{% block title %}{{pagina|default('')}}{% endblock %}

{% block body %}
<section>
    <div class="card">
        <div class="card-header">
            Filtro
        </div>
        <div class="card-body">
            <form action="{{path('reporte_abogado')}}" method="get" id="bForm">
            <div class="row">
                <div class="col-sm-12 col-md-3">
                    <select name="bCompania" class="form-control">
                        <option value="0">Todos</option>
                        {% for compania in companias %}
                            <option value="{{compania.id}}"
                            {% if bCompania==compania.id %}
                                selected
                            {% endif %}
                            >{{compania.nombre}}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-sm-12 col-md-3">
                    <input type="text" class="form-control" name="bFiltro" placeholder="Nombre abogado" value="{{bFiltro}}">
                </div>
                <div class="col-sm-12 col-md-3">
                    <input type="text" class="form-control" name="bFecha" id="bFecha" value="">
                </div>
                <div class="col-sm-12 col-md-1">
                    <button class="btn btn-primary"><i class="fas fa-search"></i></button>
                </div>
            </div>
            </form>
        </div>
    </div>
</section>

<section>
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Listado</h3>
        </div>
        <div class="card-body table-responsive p-0" style="height: 450px;">
            <table class="table table-head-fixed text-nowrap table-striped table-sm">
                <thead>
                    <tr>
                        <th scope="col">Abogado</th>
                        <th scope="col" style="text-align: right;">Total Agendado</th>
                        <th scope="col" style="text-align: right;">Asesorías Efectivas</th>
                        <th scope="col" style="text-align: right;">Contratos</th>
                        <th scope="col" style="text-align: right;">No Contrata</th>
                        <th scope="col" style="text-align: right;">Desistidos</th>
                        <th scope="col" style="text-align: right;">Cierre VirtualPos</th>
                        <th scope="col" style="text-align: right;">Honorarios Promedio</th>
                        <th scope="col" style="text-align: right;">Pagos 1ª Cuota</th>
                        <th scope="col" style="text-align: right;">Cuotas Promedio</th>
                        <th scope="col" style="text-align: right;">Pagos Totales</th>
                    </tr>
                </thead>
                <tbody>
                    {% set s_agendado = 0 %}
                    {% set s_asesorias = 0 %}
                    {% set s_contratos = 0 %}
                    {% set s_no_contrata = 0 %}
                    {% set s_desistidos = 0 %}
                    {% set s_virtualpos = 0 %}
                    {% set s_monto = 0 %}
                    {% set s_cuotas = 0 %}
                    {% set s_prim_cuota = 0 %}
                    {% set s_pag_totales = 0 %}
                    {% set cant_abogados = 0 %}

                    {% for reporte in reportes %}
                    <tr>
                        <td>{{ reporte.abogado_nombre }}</td>
                        <td align="right">{{ reporte.total_agendado }}</td>
                        <td align="right">{{ reporte.asesorias_efectivas }}</td>
                        <td align="right">{{ reporte.contratos }}</td>
                        <td align="right">{{ reporte.no_contrata }}</td>
                        <td align="right">{{ reporte.desistidos }}</td>
                        <td align="right">{{ reporte.cierre_virtualpos }}</td>
                        <td align="right">${{ reporte.honorarios_promedio|number_format(0,',','.') }}</td>
                        <td align="right">{{ reporte.pagos_primera_cuota }}</td>
                        <td align="right">{{ reporte.cuotas_promedio|number_format(1,',','.') }}</td>
                        <td align="right">{{ reporte.pagos_totales }}</td>
                    </tr>
                    {% set s_agendado    = s_agendado    + reporte.total_agendado %}
                    {% set s_asesorias   = s_asesorias   + reporte.asesorias_efectivas %}
                    {% set s_contratos   = s_contratos   + reporte.contratos %}
                    {% set s_no_contrata = s_no_contrata + reporte.no_contrata %}
                    {% set s_desistidos  = s_desistidos  + reporte.desistidos %}
                    {% set s_virtualpos  = s_virtualpos  + reporte.cierre_virtualpos %}
                    {% set s_monto       = s_monto       + reporte.honorarios_promedio %}
                    {% set s_cuotas      = s_cuotas      + reporte.cuotas_promedio %}
                    {% set s_prim_cuota  = s_prim_cuota  + reporte.pagos_primera_cuota %}
                    {% set s_pag_totales = s_pag_totales + reporte.pagos_totales %}
                    {% set cant_abogados = cant_abogados + 1 %}
                    {% else %}
                    <tr>
                        <td colspan="11">No hay registros</td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr style="text-align: right;">
                        <th></th>
                        <th>{{ s_agendado|number_format(0,',','.') }}</th>
                        <th>{{ s_asesorias|number_format(0,',','.') }}</th>
                        <th>{{ s_contratos|number_format(0,',','.') }}</th>
                        <th>{{ s_no_contrata|number_format(0,',','.') }}</th>
                        <th>{{ s_desistidos|number_format(0,',','.') }}</th>
                        <th>{{ s_virtualpos|number_format(0,',','.') }}</th>
                        <th>${{ cant_abogados > 0 ? (s_monto/cant_abogados)|number_format(0,',','.') : 0 }}</th>
                        <th>{{ s_prim_cuota|number_format(0,',','.') }}</th>
                        <th>{{ cant_abogados > 0 ? (s_cuotas/cant_abogados)|number_format(1,',','.') : 0 }}</th>
                        <th>{{ s_pag_totales|number_format(0,',','.') }}</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</section>

<script>
    $('#bFecha').daterangepicker({
        "drops": "down",
        "startDate": "{{dateInicio}}",
        "endDate": "{{dateFin}}",
        "locale": {
            "format": "YYYY-MM-DD",
            "applyLabel": "Apply",
            "cancelLabel": "Cancel"
        }
    }, function(start, end, label) {
        console.log('New date range selected: ' + start.format('YYYY-MM-DD') + ' to ' + end.format('YYYY-MM-DD'));
    });
</script>
{% endblock %}
